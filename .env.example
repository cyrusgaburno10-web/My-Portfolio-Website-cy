# Primary provider — fast, cheap streaming via Groq.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional override. Defaults to llama-3.1-70b-versatile.
# If Groq has decommissioned that model on your account, check
# https://console.groq.com/docs/models and set e.g. llama-3.3-70b-versatile.
GROQ_MODEL=

# Fallback provider — used automatically when GROQ_API_KEY is not set.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional override. Defaults to gpt-4o-mini.
OPENAI_MODEL=

# Powers the "Or Send a Message" contact form on the Book a Call section.
# Get a free key at https://resend.com/api-keys
RESEND_API_KEY=
